# Runtime
INVEST_AGENT_DB_PATH=./data/invest_agent.db
INVEST_AGENT_HOST=127.0.0.1
INVEST_AGENT_PORT=8788
INVEST_AGENT_MODE=paper

# Risk policy
INVEST_AGENT_MAX_TRADE_NOTIONAL_USD=5000
INVEST_AGENT_MAX_POSITION_PCT=35
INVEST_AGENT_APPROVAL_TTL_MINUTES=15
INVEST_AGENT_MAX_PRICE_DRIFT_BPS=30
INVEST_AGENT_MIN_CONFIDENCE=0.35
INVEST_AGENT_ALLOW_LIVE_TRADING=false
INVEST_AGENT_WATCHLIST=AAPL,MSFT,NVDA,GOOGL
INVEST_AGENT_DRAFT_NOTIONAL_USD=1000
INVEST_AGENT_DRAFT_MAX_CANDIDATES=3
INVEST_AGENT_NEWS_LOOKBACK_DAYS=3
INVEST_AGENT_NEWS_MAX_PER_SYMBOL=5
INVEST_AGENT_NEWS_MAX_SYMBOLS=6
INVEST_AGENT_NEWS_TIMEOUT_SECONDS=5
INVEST_AGENT_GOOGLE_NEWS_FALLBACK_ENABLED=true

# Optional external integrations, leave blank for the safe local MVP.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
