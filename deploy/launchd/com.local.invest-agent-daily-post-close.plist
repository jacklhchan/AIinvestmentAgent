<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.local.invest-agent-daily-post-close</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd ${INVEST_AGENT_REPO_ROOT} &amp;&amp; exec ${INVEST_AGENT_REPO_ROOT}/.venv/bin/python -m invest_agent.cli daily-post-close</string>
  </array>
  <key>WorkingDirectory</key>
  <string>${INVEST_AGENT_REPO_ROOT}</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>${INVEST_AGENT_REPO_ROOT}/.venv/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>6</integer>
    <key>Minute</key>
    <integer>15</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>${INVEST_AGENT_REPO_ROOT}/logs/invest-agent-daily-post-close.out.log</string>
  <key>StandardErrorPath</key>
  <string>${INVEST_AGENT_REPO_ROOT}/logs/invest-agent-daily-post-close.err.log</string>
</dict>
</plist>
